.SH NAME
linear-issues-update - Update an existing issue


.SH SYNOPSIS
\fBlinear issues update [ID] [flags]\fP


.SH DESCRIPTION
Update fields on an existing issue.

.PP
Examples:
  linear issues update ENG-123 --status "Done"
  linear issues update ENG-123 --title "New title" --priority 1
  linear issues update ENG-123 --assignee-me
  linear issues update ENG-123 --project "My Project"


.SH OPTIONS
\fB--assignee-me\fP[=false]
	Assign to yourself

.PP
\fB--description\fP=""
	New description

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for update

.PP
\fB--priority\fP=-1
	New priority

.PP
\fB--project\fP=""
	Project name

.PP
\fB--status\fP=""
	New status name

.PP
