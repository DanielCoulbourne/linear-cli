.SH NAME
linear-issues-list - List issues


.SH SYNOPSIS
\fBlinear issues list [flags]\fP


.SH DESCRIPTION
List issues with optional filters.

.PP
Examples:
  linear issues list                          # Your assigned issues
  linear issues list --team ENG               # Issues for team ENG
  linear issues list --status "In Progress"   # Filter by status
  linear issues list --limit 50               # Show more results
  linear issues list -o json                  # JSON output


.SH OPTIONS
\fB--assignee\fP=""
	Filter by assignee (use 'me' for yourself)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--limit\fP=25
	Maximum number of results

.PP
\fB--status\fP=""
	Filter by status name

.PP
\fB--team\fP=""
	Filter by team key (e.g. ENG)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-o\fP, \fB--output\fP="text"
	Output format: text, json


.SH SEE ALSO
\fBlinear-issues(1)\fP


